# Development - Simulation Mode
APP_NAME=RuView-Location
ENVIRONMENT=development
DEBUG=true
HOST=0.0.0.0
PORT=8080

# Mock everything - no hardware needed
MOCK_HARDWARE=true
MOCK_POSE_DATA=true
ENABLE_TEST_ENDPOINTS=true

# Disable auth for dev
ENABLE_AUTHENTICATION=false
ENABLE_RATE_LIMITING=false

# Enable WebSockets
ENABLE_WEBSOCKETS=true
ENABLE_REAL_TIME_PROCESSING=true

# Database - SQLite fallback
ENABLE_DATABASE_FAILSAFE=true
SQLITE_FALLBACK_PATH=./data/dev-sim.db

# Redis - not required
REDIS_REQUIRED=false
ENABLE_REDIS_FAILSAFE=true

# CSI Processing
CSI_SAMPLING_RATE=100
CSI_WINDOW_SIZE=256

# Streaming
STREAM_FPS=10

# Logging
LOG_LEVEL=DEBUG
LOG_FORMAT=text

# Source mode marker
RUVIEW_SOURCE_MODE=simulation
