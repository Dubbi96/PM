# Live Mode - ESP32 Hardware Connected
APP_NAME=RuView-Location
ENVIRONMENT=production
DEBUG=false
HOST=0.0.0.0
PORT=8080

# Real hardware
MOCK_HARDWARE=false
MOCK_POSE_DATA=false
ENABLE_TEST_ENDPOINTS=false

# Enable security
ENABLE_AUTHENTICATION=true
ENABLE_RATE_LIMITING=true

# WebSockets
ENABLE_WEBSOCKETS=true
ENABLE_REAL_TIME_PROCESSING=true
ENABLE_HISTORICAL_DATA=true

# Database
DATABASE_URL=sqlite:///./data/ruview-live.db
ENABLE_DATABASE_FAILSAFE=true

# Redis (optional)
REDIS_REQUIRED=false
ENABLE_REDIS_FAILSAFE=true

# CSI Processing - real rates
CSI_SAMPLING_RATE=1000
CSI_WINDOW_SIZE=512
CSI_OVERLAP=0.5
CSI_NOISE_THRESHOLD=0.1
CSI_HUMAN_DETECTION_THRESHOLD=0.8
CSI_SMOOTHING_FACTOR=0.9

# Streaming
STREAM_FPS=30

# Logging
LOG_LEVEL=WARNING
LOG_FORMAT=json
LOG_FILE=./logs/ruview-live.log

# Source mode
RUVIEW_SOURCE_MODE=esp32

# Hardware config
WIFI_INTERFACE=wlan0
HARDWARE_POLLING_INTERVAL=0.1
