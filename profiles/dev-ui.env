# Development - UI Development Mode
APP_NAME=RuView-Location
ENVIRONMENT=development
DEBUG=true
HOST=0.0.0.0
PORT=8080

# Mock hardware, real UI
MOCK_HARDWARE=true
MOCK_POSE_DATA=true
ENABLE_TEST_ENDPOINTS=true

# Disable auth
ENABLE_AUTHENTICATION=false
ENABLE_RATE_LIMITING=false

# Enable everything for UI testing
ENABLE_WEBSOCKETS=true
ENABLE_REAL_TIME_PROCESSING=true
ENABLE_HISTORICAL_DATA=true

# Database
ENABLE_DATABASE_FAILSAFE=true
SQLITE_FALLBACK_PATH=./data/dev-ui.db

# Redis
REDIS_REQUIRED=false
ENABLE_REDIS_FAILSAFE=true

# Faster updates for UI dev
STREAM_FPS=15
CSI_SAMPLING_RATE=100

# Logging
LOG_LEVEL=INFO
LOG_FORMAT=text

# Source mode
RUVIEW_SOURCE_MODE=simulation
